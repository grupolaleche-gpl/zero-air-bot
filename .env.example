# Variables de entorno para Zero Air WhatsApp Bot
# Copia este archivo como .env y llena los valores reales

# Token que tú inventas (debe coincidir con el que pones en Meta)
VERIFY_TOKEN=zeroair2024

# Token de acceso permanente de Meta (WhatsApp Business API)
# Lo obtienes en: developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_TOKEN=

# ID del número de teléfono de WhatsApp Business
# Lo ves en: developers.facebook.com → tu app → WhatsApp → API Setup
PHONE_NUMBER_ID=

# API Key de Anthropic
# La obtienes en: console.anthropic.com
ANTHROPIC_API_KEY=

# Puerto del servidor (Render/Railway lo asignan automáticamente)
PORT=3000
